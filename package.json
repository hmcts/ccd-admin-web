{
  "name": "ccd-admin-web",
  "version": "1.0.1",
  "private": true,
  "engineStrict": true,
  "engines": {
    "node": "^24.15.0"
  },
  "scripts": {
    "setup": "NODE_PATH=. yarn sass",
    "start": "yarn tsx server.js",
    "develop": "NODE_PATH=. echo \"develop\" & yarn sass:watch & yarn tsx watch --include src/main server.js",
    "debug": "NODE_PATH=. LOG_LEVEL=DEBUG yarn develop",
    "lint": "eslint .",
    "sass:watch": "NODE_PATH=. sass --watch src/main/public/stylesheets/app.scss:src/main/public/stylesheets/app.css --source-map --style=expanded --quiet --load-path=node_modules",
    "sass": "NODE_PATH=. sass src/main/public/stylesheets/app.scss:src/main/public/stylesheets/app.css --source-map --style=expanded --quiet --load-path=node_modules",
    "test:base": "NODE_ENV=test LOG_LEVEL=OFF mocha --reporter mochawesome --reporter-options reportFilename=unit,inlineAssets=true,reportTitle=ccd-admin-web-unit --exit --import=tsx",
    "test": "yarn test:base 'src/**/*.ts' --ignore '**/a11y/**'",
    "test:specific": "NODE_ENV=test LOG_LEVEL=DEBUG mocha --exit --import=tsx",
    "test:a11y": "NODE_PATH=.",
    "test:coverage": "NODE_ENV=test LOG_LEVEL=OFF nyc mocha --exit --import=tsx 'src/**/*.ts' --ignore '**/a11y/**'",
    "test:smoke": "echo 'TODO - SMOKE TESTS'",
    "test:functional": "echo 'TODO - FUNCTIONAL TESTS'",
    "fortifyScan": "./src/test/java/gradlew -p src/test/java fortifyScan",
    "suppress-cve": "yarn npm audit --recursive --environment production --json > yarn-audit-known-issues",
    "sonar-scan": "NODE_PATH=. sonar-scanner -X -Dsonar.projectKey='ccd-admin-web' -Dsonar.sources=src/main/ -Dsonar.tests=src/test/ -Dsonar.exclusions=node_modules/** -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info",
    "snyk-protect": "echo 'snyk-protect'",
    "prepare": "echo 'npm run snyk-protect'",
    "prepublish": "echo 'npm run snyk-protect'"
  },
  "dependencies": {
    "@dr.pogodin/csurf": "^1.16.9",
    "@hmcts/nodejs-healthcheck": "^1.8.6",
    "@hmcts/nodejs-logging": "^4.0.4",
    "@hmcts/properties-volume": "^1.4.0",
    "@snyk/protect": "^1.1304.0",
    "@types/node": "^24.12.2",
    "applicationinsights": "^3.14.0",
    "body-parser": "^2.2.2",
    "brace-expansion": "^5.0.5",
    "config": "^4.4.1",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "debug": "^4.4.3",
    "diff": "^8.0.4",
    "download-csv": "^1.1.1",
    "es6-promisify": "^7.0.0",
    "express": "^4.22.1",
    "express-force-https": "^1.0.0",
    "express-force-ssl": "^0.3.2",
    "express-nunjucks": "^3.1.2",
    "fast-csv": "^5.0.5",
    "formidable": "^3.5.4",
    "govuk-frontend": "^5.14.0",
    "helmet": "^8.1.0",
    "jquery": "^4.0.0",
    "jquery-validation": "^1.22.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^28.1.0",
    "jwt-decode": "^4.0.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nunjucks": "^3.2.4",
    "on-headers": "^1.1.0",
    "or": "^0.2.0",
    "otp": "^0.1.3",
    "path-to-regexp": "^8.4.2",
    "require-directory": "^2.1.1",
    "sass": "^1.99.0",
    "serve-favicon": "^2.5.1",
    "sinon-stub-promise": "^4.0.0",
    "superagent": "^10.3.0",
    "tsconfig-paths": "^4.2.0",
    "validator": "^13.15.35",
    "xss-filters": "^1.2.7"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/body-parser": "^1.19.6",
    "@types/chai-as-promised": "^8.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/serve-favicon": "^2.5.7",
    "@types/sinon-chai": "^4.0.0",
    "@types/supertest": "^7.2.0",
    "@types/xss-filters": "^1.2.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "cookie": "^1.1.1",
    "eslint": "^10.2.1",
    "eslint-plugin-mocha": "^11.2.0",
    "fetch-mock": "^12.6.0",
    "globals": "^17.5.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "karma": "^6.4.4",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "mock-session": "^0.0.5",
    "nock": "^14.0.13",
    "nyc": "^18.0.0",
    "pa11y": "^9.1.1",
    "proxyquire": "^2.1.3",
    "sinon": "^21.1.2",
    "sinon-chai": "^4.0.1",
    "sinon-express-mock": "^2.2.1",
    "sonar-scanner": "^3.1.0",
    "supertest": "^7.2.2",
    "supertest-session": "^5.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/main"
    ],
    "exclude": [
      "**/*.d.ts",
      "src/main/public",
      "src/main/modules",
      "src/main/router",
      "src/main/util",
      "src/main/app.ts",
      "src/main/server.ts"
    ],
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "report-dir": "coverage",
    "all": true
  },
  "snyk": true,
  "packageManager": "yarn@4.14.1"
}
