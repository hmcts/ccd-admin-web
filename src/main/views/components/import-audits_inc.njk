{% from "components/csrf.njk" import csrfProtection %}

{% block content %}
<table class="govuk-table">
  <caption class="govuk-table__caption govuk-table__caption--m">Most recent uploads history</caption>
  <thead class="govuk-table__head">
    <tr class="govuk-table__row">
      <th scope="col" class="govuk-table__header">Date Imported</th>
      <th scope="col" class="govuk-table__header">Who Imported</th>
      <th scope="col" class="govuk-table__header">Case Type</th>
      <th scope="col" class="govuk-table__header">Filename</th>
    </tr>
  </thead>
  <tbody class="govuk-table__body">
    {% if importAudits?.length == 0 %}
    <tr class="govuk-table__row">
      <th scope="row" class="govuk-table__header">Imports audits are not found</th>
    </tr>
    {%else%}
      {% for audit in importAudits %}
        <tr class="govuk-table__row">
          <th scope="row" class="govuk-table__header">{{audit.date_imported}}</th>
          <td class="govuk-table__cell">{{audit.who_imported}}</td>
          <td class="govuk-table__cell">{{audit.case_type}}</td>
          <td class="govuk-table__cell">{{audit.filename}}</td>
        </tr>
      {% endfor %}
    {% endif %}
  </tbody>
</table>
{% endblock %}

